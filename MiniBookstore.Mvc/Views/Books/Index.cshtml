@model List<BookListItemViewModel>

@{
    ViewData["Title"] = "Danh Mục Sách";
    var totalItems = Model.Count;
}

<div class="page-header">
    <div>
        <h2 class="page-title">Danh Mục Sách</h2>
        <p class="page-description">
            Đây là trang danh sách sách của hiệu sách.
            Giao diện được render bằng Partial View.
        </p>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-secondary"
           asp-controller="Books"
           asp-action="Filter">
            Lọc sách
        </a>

        <a class="btn btn-secondary"
           asp-controller="Books"
           asp-action="Search">
            Tìm kiếm sách
        </a>

        <a class="btn btn-primary"
           asp-controller="Books"
           asp-action="Create">
            Thêm sách mới
        </a>
    </div>
</div>

<div class="data-layer-dashboard">
    <h3 class="dashboard-title">Data Layer Dashboard</h3>
    <div class="flow-diagram">
        <div class="flow-box">Controller</div>
        <div class="flow-arrow">→</div>
        <div class="flow-box">Service</div>
        <div class="flow-arrow">→</div>
        <div class="flow-box">Repository</div>
        <div class="flow-arrow">→</div>
        <div class="flow-box">DbContext</div>
        <div class="flow-arrow">→</div>
        <div class="flow-box">Database</div>
    </div>
    <div class="dashboard-description">
        Khi truy cập <strong>/Books</strong>, danh sách sách được lấy theo luồng: Controller → Service → Repository → DbContext → Database.<br>
        Dữ liệu không còn được hardcode trong Controller, mà được lấy từ Database thông qua EF Core.
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">
        @TempData["SuccessMessage"]
    </div>
}

<div class="info-panel">
    <strong>Tổng số đầu sách:</strong> @totalItems
</div>

@if (Model.Count == 0)
{
    <p>Chưa có sách nào trong hệ thống.</p>
}
else
{
    <div class="book-grid">
        @foreach (var item in Model)
        {
            <partial name="_BookCard" model="item" />
        }
    </div>
}

<p class="mt-4">
    <a class="btn btn-light"
       asp-controller="Home"
       asp-action="Index">
        Quay lại trang chủ
    </a>
</p>
