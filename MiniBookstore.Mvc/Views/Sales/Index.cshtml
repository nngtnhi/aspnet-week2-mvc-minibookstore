@model List<SaleHistoryViewModel>

@{
    ViewData["Title"] = "Lịch sử bán sách";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Lịch sử bán sách</h2>
        <p class="page-description">
            Dữ liệu chỉ đọc qua AsNoTracking.
        </p>
    </div>

    <a class="btn btn-primary" asp-controller="Sales" asp-action="Create">Tạo đơn mới</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">@TempData["SuccessMessage"]</div>
}

@if (Model.Count == 0)
{
    <p>Chưa có đơn bán nào.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Tên khách hàng</th>
                <th>Thời gian</th>
                <th>Sách</th>
                <th>Số lượng</th>
                <th>Tổng tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sale in Model)
            {
                <tr>
                    <td>#@sale.Id</td>
                    <td>@sale.CustomerName</td>
                    <td>@sale.CreatedAtText</td>
                    <td>
                        @foreach (var item in sale.Items)
                        {
                            <div>@item.BookTitle</div>
                        }
                    </td>
                    <td>
                        @foreach (var item in sale.Items)
                        {
                            <div>@item.Quantity</div>
                        }
                    </td>
                    <td>@sale.TotalAmountText</td>
                </tr>
            }
        </tbody>
    </table>
}
